local function createHighlight(obj, color, name)
    if obj:FindFirstChild("ESP_Highlight") then return end
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.FillColor = color
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0
    highlight.Parent = obj
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_Label"
    billboard.Size = UDim2.new(0, 100, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = obj
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 14
    label.Font = Enum.Font.GothamBold
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.Parent = billboard
end

local function isMonster(obj)
    local name = obj.Name:lower()
    for monster, config in pairs(MonsterConfig) do
        if name:find(monster:lower()) then
            return true, monster, config
        end
    end
    return false, nil, nil
end

local function updateESP()
    local closestMonster = nil
    local closestDist = math.huge
    local closestConfig = nil
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local highlight = obj:FindFirstChild("ESP_Highlight")
        local label = obj:FindFirstChild("ESP_Label")
        local shouldShow = false
        local color = Color3.fromRGB(255, 255, 255)
        local displayName = obj.Name
        
        -- Монстры
        local isMonsterObj, monsterType, monsterConfig = isMonster(obj)
        if isMonsterObj and Settings.ESP_Monsters then
            shouldShow = true
            color = monsterConfig.color
            displayName = monsterType
            
            -- Проверка расстояния для уведомлений
            if Settings.MonsterWarnings and LocalPlayer.Character then
                local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local objPos = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
                    local dist = (objPos - root.Position).Magnitude
                    if dist <= monsterConfig.dist then
                        if dist < closestDist then
                            closestDist = dist
                            closestMonster = monsterType
                            closestConfig = monsterConfig
                        end
                    end
                end
            end
        end
        
        -- Предметы
        if not shouldShow and Settings.ESP_Items then
            local nameLower = obj.Name:lower()
            if obj:IsA("Tool") or nameLower:find("key") or nameLower:find("lockpick") 
                or nameLower:find("vitamin") or nameLower:find("flashlight") 
                or nameLower:find("lighter") or nameLower:find("gold") 
                or nameLower:find("coin") or nameLower:find("battery") then
                shouldShow = true
                color = Color3.fromRGB(255, 255, 0)
                displayName = "📦 " .. obj.Name
            end
        end
        
        -- Двери
        if not shouldShow and Settings.ESP_Doors then
            if obj:IsA("Model") and obj.Name:lower():find("door") then
                shouldShow = true
                color = Color3.fromRGB(0, 255, 0)
                displayName = "🚪 " .. obj.Name
            end
        end
        
        -- Шкафы/укрытия
        if not shouldShow and Settings.ESP_Closets then
            local nameLower = obj.Name:lower()
            if obj:IsA("Model") and (nameLower:find("wardrobe") or nameLower:find("closet") or nameLower:find("bed")) then
                shouldShow = true
                color = Color3.fromRGB(139, 69, 19)
                displayName = "🗄️ " .. obj.Name
            end
        end
        
        -- Книги в библиотеке
        if not shouldShow and Settings.ESP_Books then
            local nameLower = obj.Name:lower()
            if obj:IsA("BasePart") and (nameLower:find("book") or nameLower:find("paper")) then
                shouldShow = true
                color = Color3.fromRGB(255, 215, 0)
                displayName = "📚 " .. obj.Name
            end
        end
        
        -- Игроки
        if not shouldShow and Settings.ESP_Players then
            if obj:IsA("Model") then
                local player = Players:GetPlayerFromCharacter(obj)
                if player and player ~= LocalPlayer then
                    shouldShow = true
                    color = Color3.fromRGB(0, 100, 255)
                    displayName = "👤 " .. player.Name
                end
            end
        end
        
        if shouldShow then
            if not highlight and not label then
                createHighlight(obj, color, displayName)
            end
            if label and LocalPlayer.Character then
                local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local objPos = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
                    local distance = (objPos - root.Position).Magnitude
                    label.TextLabel.Text = displayName .. " [" .. math.floor(distance) .. "m]"
                end
            end
        else
            if highlight then highlight:Destroy() end
            if label then label:Destroy() end
        end
    end
    
    -- Показываем уведомление о ближайшем монстре
    if closestMonster and closestConfig then
        WarningFrame.Visible = true
        WarningLabel.Text = closestConfig.warning
        WarningLabel.TextColor3 = closestConfig.color
        WarningDistance.Text = "Расстояние: " .. math.floor(closestDist) .. "m"
    else
        WarningFrame.Visible = false
    end
end

