-- Полёт
local flying = false
local flySpeed = 50
local bg, bv

local function startFly()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not root or not hum then return end
    flying = true
    bg = Instance.new("BodyGyro")
    bg.P = 9e4
    bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.CFrame = root.CFrame
    bg.Parent = root
    bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bv.Velocity = Vector3.zero
    bv.Parent = root
    hum.PlatformStand = true
end

local function stopFly()
    flying = false
    if bg then bg:Destroy() end
    if bv then bv:Destroy() end
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then hum.PlatformStand = false end
end

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.F and Settings.Fly then
        if flying then stopFly() else startFly() end
    end
end)

RunService.RenderStepped:Connect(function()
    if flying and Settings.Fly then
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local cam = workspace.CurrentCamera
            local move = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then move += cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then move -= cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then move -= cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then move += cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then move -= Vector3.new(0, 1, 0) end
            if bv then bv.Velocity = move * flySpeed end
            if bg then bg.CFrame = cam.CFrame end
        end
    end
end)

-- ESP (Подсветка всего)
local function createHighlight(obj, color, name)
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.FillColor = color
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0
    highlight.Parent = obj
    
    -- Создаём текстовую метку с расстоянием
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_Label"
    billboard.Size = UDim2.new(0, 100, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = obj
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 14
    label.Font = Enum.Font.GothamBold
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.Parent = billboard
    
    return highlight, billboard
end

-- Список известных монстров DOORS
local monsterNames = {
    "Rush", "Ambush", "Screech", "Seek", "Figure", "Eyes", "Halt", "Jack", 
    "Hide", "Timothy", "Window", "Shadow", "Dupe", "Snare"
}

local function isMonster(obj)
    if not obj:IsA("Model") and not obj:IsA("BasePart") then return false end
    local nameLower = obj.Name:lower()
    for _, monster in ipairs(monsterNames) do
        if nameLower:find(monster:lower()) then
            return true, monster
        end
    end
    return false, nil
end

local function updateESP()
    -- Очищаем старые подсветки
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local highlight = obj:FindFirstChild("ESP_Highlight")
        local label = obj:FindFirstChild("ESP_Label")
        
        local shouldShow = false
        local color = Color3.fromRGB(255, 255, 255)
        local displayName = obj.Name
        
        -- Монстры
        local isMonsterObj, monsterType = isMonster(obj)
        if isMonsterObj and Settings.ESP_Monsters then
            shouldShow = true
            if monsterType == "Seek" then
                color = Color3.fromRGB(255, 0, 0) -- Красный для Лисы
            elseif monsterType == "Rush" or monsterType == "Ambush" then
                color = Color3.fromRGB(255, 100, 0) -- Оранжевый
            elseif monsterType == "Figure" then
                color = Color3.fromRGB(150, 0, 255) -- Фиолетовый
            else
                color = Color3.fromRGB(255, 50, 50)
            end
            displayName = monsterType
        end
        
        -- Предметы
        if not shouldShow and Settings.ESP_Items then
            local nameLower = obj.Name:lower()
            if obj:IsA("Tool") or nameLower:find("key") or nameLower:find("lockpick") 
                or nameLower:find("vitamin") or nameLower:find("flashlight") 
                or nameLower:find("lighter") or nameLower:find("gold") 
                or nameLower:find("coin") or nameLower:find("battery") then
                shouldShow = true
                color = Color3.fromRGB(255, 255, 0) -- Жёлтый
                displayName = "📦 " .. obj.Name
            end
        end
        
        -- Двери
        if not shouldShow and Settings.ESP_Doors then
            if obj:IsA("Model") and obj.Name:lower():find("door") then
                shouldShow = true
                color = Color3.fromRGB(0, 255, 0) -- Зелёный
                displayName = "🚪 " .. obj.Name
            end
        end
        
        -- Игроки
        if not shouldShow and Settings.ESP_Players then
            if obj:IsA("Model") then
                local player = Players:GetPlayerFromCharacter(obj)
                if player and player ~= LocalPlayer then
                    shouldShow = true
                    color = Color3.fromRGB(0, 100, 255) -- Синий
                    displayName = "👤 " .. player.Name
                end
            end
        end
        
        if shouldShow then
            if not highlight and not label then
                createHighlight(obj, color, displayName)
            end
            -- Обновляем расстояние
            if label and LocalPlayer.Character then
                local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local objPos = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
                    local distance = (objPos - root.Position).Magnitude
                    label.TextLabel.Text = displayName .. " [" .. math.floor(distance) .. "m]"
                end
            end
        else
            if highlight then highlight:Destroy() end
            if label then label:Destroy() end
        end
    end
end

RunService.Heartbeat:Connect(updateESP)

